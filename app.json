{
  "expo": {
    "name": "ai-visual-app",
    "slug": "ai-visual-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aivisualapp",
    "userInterfaceStyle": "automatic",

    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to analyze surroundings and assist visually impaired users.",
        "NSMicrophoneUsageDescription": "Microphone access may be required for voice interactions."
      }
    },

    "android": {
      "package": "com.manojkumar33.aivisualapp",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "INTERNET"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      }
    },

    "web": {
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
  "expo-router",
  "expo-camera",
  [
    "expo-splash-screen",
    {
      "image": "./assets/images/splash-icon.png",
      "imageWidth": 200,
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    }
  ]
],

    "extra": {
      "router": {},
      "eas": {
        "projectId": "de626243-f003-4689-88ce-4f634c083789"
      }
    },

    "owner": "manojkumar33"
  }
}